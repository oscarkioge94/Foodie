rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Recipes collection
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Articles collection
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Admin config collection
    match /admin_config/{configId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
